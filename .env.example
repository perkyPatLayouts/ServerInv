# Database Configuration
# The database type is auto-detected from the protocol:
#   postgres:// or postgresql:// → PostgreSQL
#   mysql://                     → MySQL/MariaDB

# PostgreSQL (recommended for VPS deployments)
DATABASE_URL=postgres://serverinv:CHANGE_THIS_PASSWORD@localhost:5432/serverinv

# MySQL/MariaDB (alternative for shared hosting)
# DATABASE_URL=mysql://serverinv:CHANGE_THIS_PASSWORD@localhost:3306/serverinv

# JWT secret for token signing (REQUIRED - must be a strong random string)
# Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_THIS_TO_RANDOM_STRING

# Server port
PORT=3000

# Allowed CORS origins (comma-separated)
# Example: http://localhost:5173,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: Deployment Configuration
# DEPLOYMENT_TYPE - Deployment environment type
#   Options: vps, shared
#   Default: vps
# DEPLOYMENT_TYPE=vps

# CONTROL_PANEL - Control panel in use (for shared hosting only)
#   Options: none, cpanel, directadmin
#   Default: none
# CONTROL_PANEL=none

# TMP_DIR - Temporary directory for backups and uploads
#   Default: /tmp (VPS) or ~/serverinv/tmp (shared hosting)
# TMP_DIR=/tmp
