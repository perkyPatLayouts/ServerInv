# Database connection string
# Format: postgres://username:password@host:port/database
DATABASE_URL=postgres://serverinv:CHANGE_THIS_PASSWORD@localhost:5432/serverinv

# JWT secret for token signing (REQUIRED - must be a strong random string)
# Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_THIS_TO_RANDOM_STRING

# Server port
PORT=3000

# Allowed CORS origins (comma-separated)
# Example: http://localhost:5173,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: Deployment Configuration
# DEPLOYMENT_TYPE - Deployment environment type
#   Options: vps, shared
#   Default: vps
#   Used for: Feature detection, backup method selection
# DEPLOYMENT_TYPE=vps

# CONTROL_PANEL - Control panel in use (for shared hosting only)
#   Options: none, cpanel, directadmin
#   Default: none
#   Used for: Deployment scripts, feature detection
# CONTROL_PANEL=none

# TMP_DIR - Temporary directory for backups and uploads
#   Default: /tmp (VPS) or ~/serverinv/tmp (shared hosting)
#   Must be writable by the application user
# TMP_DIR=/tmp
